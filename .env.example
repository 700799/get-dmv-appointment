# Gmail credentials for sending notifications and weekly passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address to receive alerts and the weekly password
NOTIFY_EMAIL=you@example.com

# Protect cron endpoints — set a long random string, include it in no public docs
CRON_SECRET=replace-with-random-secret

# JWT signing secret — set a long random string
SESSION_SECRET=replace-with-another-random-secret

# Vercel KV — auto-populated when you link a KV database in the Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=
