# Gmail credentials for sending notifications and weekly passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address to receive alerts and the weekly password
NOTIFY_EMAIL=you@example.com

# Protect cron endpoints — set a long random string (e.g. openssl rand -hex 32)
CRON_SECRET=replace-with-random-secret

# JWT signing secret — set a different long random string
SESSION_SECRET=replace-with-another-random-secret

# ScraperAPI — routes DMV checks through US residential IPs to avoid datacenter blocks
# Sign up at scraperapi.com. Free tier = 5,000 req/mo (enough for business-hours-only checks)
SCRAPER_API_KEY=your_scraperapi_key_here

# Personal info required by the CA DMV behind-the-wheel appointment form.
# CA driver's license / learner's permit format: one capital letter + 7 digits
# Example below is a realistic placeholder for a 21-year-old — replace with your own.
DMV_FIRST_NAME=Alex
DMV_LAST_NAME=Martinez
DMV_DL_NUMBER=B5683214
DMV_BIRTH_MONTH=06
DMV_BIRTH_DAY=15
DMV_BIRTH_YEAR=2004

# Upstash Redis — auto-populated when you install the Upstash Redis integration
# from the Vercel Marketplace (marketplace.vercel.com/integrations/upstash-redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
